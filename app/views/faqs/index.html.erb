<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-1 text-gray-900">FAQs</h1>
      <p class="text-3 text-gray-600 mt-2">Manage frequently asked questions for better chatbot responses</p>
    </div>
    <%= link_to "New FAQ", new_faq_path, class: "btn btn-primary" %>
  </div>

  <!-- FAQs Table -->
  <div class="card">
    <% if @faqs.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Question
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Answer Preview
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Status
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Created
              </th>
              <th scope="col" class="relative px-6 py-3">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @faqs.each do |faq| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4">
                  <div class="text-3 font-semibold text-gray-900 max-w-sm">
                    <%= truncate(faq.question, length: 80) %>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-3 text-gray-900 max-w-md">
                    <%= truncate(faq.answer, length: 100) %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if faq.active %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Active
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      Inactive
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-3 text-gray-500">
                  <%= faq.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-3 font-medium space-x-2">
                  <%= link_to "View", faq_path(faq), class: "text-blue-600 hover:text-blue-900" %>
                  <%= link_to "Edit", edit_faq_path(faq), class: "text-yellow-600 hover:text-yellow-900" %>
                  <%= link_to "Delete", faq_path(faq), 
                      method: :delete, 
                      class: "text-red-600 hover:text-red-900",
                      data: { 
                        confirm: "Are you sure you want to delete this FAQ? This action cannot be undone." 
                      } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-2 text-gray-900 mt-4">No FAQs yet</h3>
        <p class="text-3 text-gray-500 mt-2">Get started by creating your first frequently asked question.</p>
        <div class="mt-6">
          <%= link_to "Create New FAQ", new_faq_path, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>