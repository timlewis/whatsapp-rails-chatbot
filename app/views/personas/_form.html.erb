<%= form_with model: persona, local: true, class: "space-y-6" do |form| %>
  <% if persona.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(persona.errors.count, "error") %> prohibited this persona from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% persona.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Basic Information -->
    <div class="card">
      <h3 class="text-2 text-gray-900 mb-4">Basic Information</h3>
      
      <div class="space-y-4">
        <div>
          <%= form.label :name, class: "form-label" %>
          <%= form.text_field :name, class: "form-input", placeholder: "Enter persona name" %>
        </div>

        <div>
          <%= form.label :description, class: "form-label" %>
          <%= form.text_area :description, 
              class: "form-input", 
              rows: 3, 
              placeholder: "Brief description of this persona's purpose and personality" %>
        </div>

        <div class="flex items-center">
          <%= form.check_box :config_default, 
              class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
          <%= form.label :config_default, "Set as default persona", 
              class: "ml-2 text-3 text-gray-700" %>
          <div class="ml-2">
            <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20" 
                 title="Only one persona can be set as default at a time">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Preview -->
    <div class="card">
      <h3 class="text-2 text-gray-900 mb-4">Preview</h3>
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 space-y-2">
        <div class="flex items-center space-x-2">
          <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
            </svg>
          </div>
          <div>
            <div class="text-3 font-semibold text-gray-900" id="preview-name">
              <%= persona.name.present? ? persona.name : "New Persona" %>
            </div>
            <div class="text-4 text-gray-500" id="preview-description">
              <%= persona.description.present? ? persona.description : "Description will appear here..." %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Base Prompt -->
  <div class="card">
    <h3 class="text-2 text-gray-900 mb-4">Base Prompt</h3>
    <p class="text-3 text-gray-600 mb-4">
      This prompt defines how the AI will behave and respond. Be specific about personality, tone, and any special instructions.
    </p>
    
    <%= form.text_area :base_prompt, 
        class: "form-input font-mono", 
        rows: 8, 
        placeholder: "You are a helpful and friendly AI assistant. You should be..." %>
    
    <div class="mt-2 text-4 text-gray-500">
      Characters: <span id="prompt-count"><%= persona.base_prompt&.length || 0 %></span>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-200">
    <%= link_to "Cancel", 
        persona.persisted? ? persona_path(persona) : personas_path, 
        class: "btn btn-secondary" %>
    
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>

<script>
  // Live preview updates
  document.addEventListener('DOMContentLoaded', function() {
    const nameInput = document.getElementById('persona_name');
    const descriptionInput = document.getElementById('persona_description');
    const promptInput = document.getElementById('persona_base_prompt');
    const previewName = document.getElementById('preview-name');
    const previewDescription = document.getElementById('preview-description');
    const promptCount = document.getElementById('prompt-count');

    if (nameInput && previewName) {
      nameInput.addEventListener('input', function() {
        previewName.textContent = this.value || 'New Persona';
      });
    }

    if (descriptionInput && previewDescription) {
      descriptionInput.addEventListener('input', function() {
        previewDescription.textContent = this.value || 'Description will appear here...';
      });
    }

    if (promptInput && promptCount) {
      promptInput.addEventListener('input', function() {
        promptCount.textContent = this.value.length;
      });
    }
  });
</script>