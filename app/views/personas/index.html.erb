<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-1 text-gray-900">Personas</h1>
      <p class="text-3 text-gray-600 mt-2">Manage AI personalities for your chatbot</p>
    </div>
    <%= link_to "New Persona", new_persona_path, class: "btn btn-primary" %>
  </div>

  <!-- Personas Table -->
  <div class="card">
    <% if @personas.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Name
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Description
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Status
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Created
              </th>
              <th scope="col" class="relative px-6 py-3">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @personas.each do |persona| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div>
                      <div class="text-3 font-semibold text-gray-900">
                        <%= persona.name %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-3 text-gray-900 max-w-xs truncate">
                    <%= persona.description %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if persona.config_default %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Default
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      Available
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-3 text-gray-500">
                  <%= persona.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-3 font-medium space-x-2">
                  <%= link_to "View", persona_path(persona), class: "text-blue-600 hover:text-blue-900" %>
                  <%= link_to "Edit", edit_persona_path(persona), class: "text-yellow-600 hover:text-yellow-900" %>
                  <%= link_to "Delete", persona_path(persona), 
                      method: :delete, 
                      class: "text-red-600 hover:text-red-900",
                      data: { 
                        confirm: "Are you sure you want to delete '#{persona.name}'? This action cannot be undone." 
                      } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
        </svg>
        <h3 class="text-2 text-gray-900 mt-4">No personas yet</h3>
        <p class="text-3 text-gray-500 mt-2">Get started by creating your first AI persona.</p>
        <div class="mt-6">
          <%= link_to "Create New Persona", new_persona_path, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
