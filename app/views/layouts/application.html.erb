<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "WhatsApp Chatbot Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <% if authenticated? %>
      <!-- Navigation Header -->
      <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <!-- Logo/Title -->
            <div class="flex items-center">
              <%= link_to root_path, class: "text-1 text-gray-900 hover:text-gray-700 transition-colors duration-200" do %>
                WhatsApp Chatbot Admin
              <% end %>
            </div>

            <!-- Navigation Links -->
            <nav class="hidden md:flex space-x-8">
              <%= link_to "Personas", personas_path, class: "text-3 text-gray-700 hover:text-gray-900" %>
              <%= link_to "Users", users_path, class: "text-3 text-gray-700 hover:text-gray-900" %>
              <%= link_to "Chats", chats_path, class: "text-3 text-gray-700 hover:text-gray-900" %>
              <%= link_to "Messages", messages_path, class: "text-3 text-gray-700 hover:text-gray-900" %>
              <%= link_to "Tool Calls", tool_calls_path, class: "text-3 text-gray-700 hover:text-gray-900" %>
              
              <!-- Admin Dropdown -->
              <div class="relative">
                <button type="button" class="flex items-center text-3 text-gray-700 hover:text-gray-900 focus:outline-none focus:text-gray-900" id="admin-menu-button" onclick="toggleAdminMenu()">
                  <span>Admin</span>
                  <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                </button>
                
                <!-- Admin Dropdown Menu -->
                <div id="admin-menu" class="hidden absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50 border border-gray-200">
                  <%= link_to "Admin Users", admin_users_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= link_to "Background Jobs", "/jobs", class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                </div>
              </div>
            </nav>

            <!-- User Menu -->
            <div class="relative">
              <div class="flex items-center">
                <button type="button" class="flex items-center text-4 text-gray-600 hover:text-gray-900 focus:outline-none focus:text-gray-900" id="user-menu-button" onclick="toggleUserMenu()">
                  <span class="mr-1"><%= Current.admin_user&.email_address %></span>
                  <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                </button>
              </div>

              <!-- Dropdown Menu -->
              <div id="user-menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50 border border-gray-200">
                <%= link_to "Change Password", account_password_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                <%= link_to "Logout", session_path, 
                    data: { 
                      "turbo-method": "delete",
                      confirm: "Are you sure?" 
                    }, 
                    class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
              </div>
            </div>
          </div>

          <!-- Mobile Navigation -->
          <div class="md:hidden">
            <nav class="space-y-1 py-4">
              <%= link_to "Personas", personas_path, class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
              <%= link_to "Users", users_path, class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
              <%= link_to "Chats", chats_path, class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
              <%= link_to "Messages", messages_path, class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
              <%= link_to "Tool Calls", tool_calls_path, class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
              <%= link_to "Admin Users", admin_users_path, class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
              <%= link_to "Background Jobs", "/jobs", class: "block text-3 text-gray-700 hover:text-gray-900 py-2" %>
            </nav>
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Flash Messages -->
        <% flash.each do |type, message| %>
          <div class="<%= flash_class_for(type) %> p-4 rounded-md mb-6">
            <p class="text-4"><%= message %></p>
          </div>
        <% end %>

        <%= yield %>
      </main>
    <% else %>
      <!-- Unauthenticated Layout -->
      <div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
        <div class="sm:mx-auto sm:w-full sm:max-w-md">
          <div class="card">
            <!-- Flash Messages for Login -->
            <% flash.each do |type, message| %>
              <div class="<%= flash_class_for(type) %> p-4 rounded-md mb-6">
                <p class="text-4"><%= message %></p>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </div>
    <% end %>

    <script>
      // User dropdown menu functionality
      function toggleUserMenu() {
        const menu = document.getElementById('user-menu');
        const adminMenu = document.getElementById('admin-menu');
        
        // Close admin menu if it's open
        if (adminMenu && !adminMenu.classList.contains('hidden')) {
          adminMenu.classList.add('hidden');
        }
        
        menu.classList.toggle('hidden');
      }

      // Admin dropdown menu functionality
      function toggleAdminMenu() {
        const menu = document.getElementById('admin-menu');
        const userMenu = document.getElementById('user-menu');
        
        // Close user menu if it's open
        if (userMenu && !userMenu.classList.contains('hidden')) {
          userMenu.classList.add('hidden');
        }
        
        menu.classList.toggle('hidden');
      }

      // Close dropdowns when clicking outside
      document.addEventListener('click', function(event) {
        const userMenu = document.getElementById('user-menu');
        const userButton = document.getElementById('user-menu-button');
        const adminMenu = document.getElementById('admin-menu');
        const adminButton = document.getElementById('admin-menu-button');
        
        // Close user menu if clicking outside
        if (userMenu && userButton && !userButton.contains(event.target) && !userMenu.contains(event.target)) {
          userMenu.classList.add('hidden');
        }
        
        // Close admin menu if clicking outside
        if (adminMenu && adminButton && !adminButton.contains(event.target) && !adminMenu.contains(event.target)) {
          adminMenu.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
