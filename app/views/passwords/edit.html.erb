<div class="space-y-6">
  <!-- Page Header -->
  <div class="text-center">
    <h1 class="text-1 text-gray-900">Update your password</h1>
    <p class="text-3 text-gray-600 mt-2">Enter your new password below to complete the reset process.</p>
  </div>

  <!-- Password Reset Form -->
  <%= form_with url: password_path(params[:token]), method: :put, local: true, class: "space-y-6" do |form| %>
    
    <!-- New Password Field -->
    <div>
      <%= form.label :password, "New Password", class: "form-label" %>
      <%= form.password_field :password, 
          required: true, 
          autocomplete: "new-password", 
          placeholder: "Enter new password", 
          maxlength: 72,
          class: "form-input" %>
    </div>

    <!-- Confirm Password Field -->
    <div>
      <%= form.label :password_confirmation, "Confirm Password", class: "form-label" %>
      <%= form.password_field :password_confirmation, 
          required: true, 
          autocomplete: "new-password", 
          placeholder: "Repeat new password", 
          maxlength: 72,
          class: "form-input" %>
    </div>

    <!-- Submit Button -->
    <div>
      <%= form.submit "Update Password", class: "btn btn-primary w-full" %>
    </div>

    <!-- Back to Login Link -->
    <div class="text-center">
      <%= link_to "← Back to Sign In", new_session_path, 
          class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
    </div>
  <% end %>
</div>
