<div class="space-y-6">
  <!-- Navigation -->
  <div class="flex items-center space-x-2 text-3 text-gray-500">
    <%= link_to "← Back to Chats", chats_path, class: "text-blue-600 hover:text-blue-900" %>
    <span>/</span>
    <span class="text-gray-900">Chat #<%= @chat.id %></span>
  </div>

  <!-- Chat Header -->
  <div class="card">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <div class="flex-shrink-0">
          <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
        <div>
          <h1 class="text-1 text-gray-900">Chat Conversation #<%= @chat.id %></h1>
          <div class="flex items-center space-x-4 text-3 text-gray-600 mt-2">
            <span>User: <%= @chat.user&.whatsapp_number || "Unknown User" %></span>
            <span>Model: <%= @chat.model_id %></span>
            <span><%= pluralize(@messages.count, 'message') %></span>
            <span>Last active <%= time_ago_in_words(@chat.updated_at) %> ago</span>
          </div>
        </div>
      </div>
      <div class="flex space-x-3">
        <%= link_to "View All Messages", messages_path(chat_id: @chat.id), class: "btn btn-secondary" %>
        <%= link_to "View User", user_path(@chat.user), class: "btn btn-primary" if @chat.user %>
      </div>
    </div>
  </div>

  <!-- Chat Statistics -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="card">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-4 font-medium text-gray-600">User Messages</p>
          <p class="text-2 font-semibold text-gray-900"><%= @stats[:user_messages] %></p>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"/>
              <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"/>
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-4 font-medium text-gray-600">AI Messages</p>
          <p class="text-2 font-semibold text-gray-900"><%= @stats[:assistant_messages] %></p>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-4 font-medium text-gray-600">Tool Calls</p>
          <p class="text-2 font-semibold text-gray-900"><%= @stats[:tool_calls] %></p>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
            </svg>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-4 font-medium text-gray-600">Total Tokens</p>
          <p class="text-2 font-semibold text-gray-900"><%= number_with_delimiter(@stats[:total_tokens]) %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Chat Messages -->
  <div class="card">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2 font-semibold text-gray-900">Conversation History</h2>
      <div class="text-4 text-gray-500">
        <%= pluralize(@messages.count, 'message') %> • Started <%= @chat.created_at.strftime("%b %d, %Y") %>
      </div>
    </div>

    <% if @messages.any? %>
      <div class="space-y-4">
        <% @messages.each do |message| %>
          <div class="flex items-start space-x-4 p-4 rounded-lg
            <%= case message.role
                when 'user' then 'bg-green-50 border-l-4 border-green-200'
                when 'assistant' then 'bg-blue-50 border-l-4 border-blue-200'
                when 'system' then 'bg-orange-50 border-l-4 border-orange-200'
                else 'bg-gray-50 border-l-4 border-gray-200'
                end %>">
            
            <!-- Message Avatar -->
            <div class="flex-shrink-0">
              <% case message.role %>
              <% when 'user' %>
                <div class="h-8 w-8 bg-green-100 rounded-full flex items-center justify-center">
                  <svg class="h-4 w-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
                  </svg>
                </div>
              <% when 'assistant' %>
                <div class="h-8 w-8 bg-blue-100 rounded-full flex items-center justify-center">
                  <svg class="h-4 w-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"/>
                    <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"/>
                  </svg>
                </div>
              <% when 'system' %>
                <div class="h-8 w-8 bg-orange-100 rounded-full flex items-center justify-center">
                  <svg class="h-4 w-4 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                  </svg>
                </div>
              <% else %>
                <div class="h-8 w-8 bg-gray-100 rounded-full flex items-center justify-center">
                  <svg class="h-4 w-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zM7 8H5v2h2V8zm2 0h2v2H9V8zm6 0h-2v2h2V8z" clip-rule="evenodd"/>
                  </svg>
                </div>
              <% end %>
            </div>

            <!-- Message Content -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center space-x-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                    <%= case message.role
                        when 'user' then 'bg-green-100 text-green-800'
                        when 'assistant' then 'bg-blue-100 text-blue-800'  
                        when 'system' then 'bg-orange-100 text-orange-800'
                        else 'bg-gray-100 text-gray-800'
                        end %>">
                    <%= message.role&.capitalize %>
                  </span>
                  <span class="text-4 text-gray-500">
                    <%= message.created_at.strftime("%I:%M %p") %>
                  </span>
                  <% if message.tool_calls.any? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      <%= pluralize(message.tool_calls.count, 'tool call') %>
                    </span>
                  <% end %>
                </div>
                <div class="flex items-center space-x-2">
                  <% if message.input_tokens.present? || message.output_tokens.present? %>
                    <span class="text-4 text-gray-500">
                      <% total_tokens = (message.input_tokens || 0) + (message.output_tokens || 0) %>
                      <%= number_with_delimiter(total_tokens) %> tokens
                    </span>
                  <% end %>
                  <%= link_to "Details", message_path(message), class: "text-blue-600 hover:text-blue-900 text-4" %>
                </div>
              </div>

              <!-- Message Text -->
              <div class="prose max-w-none">
                <div class="text-3 text-gray-900 whitespace-pre-wrap break-words">
                  <%= message.content %>
                </div>
              </div>

              <!-- Tool Calls Preview -->
              <% if message.tool_calls.any? %>
                <div class="mt-4 space-y-2">
                  <h4 class="text-4 font-medium text-gray-700">Tool Calls:</h4>
                  <% message.tool_calls.each do |tool_call| %>
                    <div class="bg-white rounded border border-purple-200 p-3">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="text-3 font-medium text-gray-900"><%= tool_call.name %></span>
                          <% if tool_call.result.present? %>
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                              Completed
                            </span>
                          <% else %>
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">
                              No Result
                            </span>
                          <% end %>
                        </div>
                        <%= link_to "View", tool_call_path(tool_call), class: "text-blue-600 hover:text-blue-900 text-4" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <h3 class="text-2 text-gray-900 mt-4">No messages in this chat</h3>
        <p class="text-3 text-gray-500 mt-2">This conversation hasn't started yet.</p>
      </div>
    <% end %>
  </div>
</div>
