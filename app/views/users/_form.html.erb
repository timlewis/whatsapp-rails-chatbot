<%= form_with model: user, local: true, class: "space-y-6" do |form| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card">
    <h3 class="text-2 text-gray-900 mb-4">User Information</h3>
    
    <div class="space-y-4">
      <div>
        <%= form.label :whatsapp_number, class: "form-label" %>
        <%= form.text_field :whatsapp_number, 
            class: "form-input", 
            placeholder: "+1234567890",
            pattern: "^\+[1-9]\d{1,14}$",
            title: "Please enter a valid WhatsApp number starting with country code (e.g., +1234567890)" %>
        <p class="mt-1 text-4 text-gray-500">
          Include the country code (e.g., +1 for US, +44 for UK)
        </p>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-200">
    <%= link_to "Cancel", 
        user.persisted? ? user_path(user) : users_path, 
        class: "btn btn-secondary" %>
    
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>