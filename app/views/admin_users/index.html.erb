<div class="space-y-8">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-1 text-gray-900">Admin Users</h1>
      <p class="text-3 text-gray-600 mt-2">Manage administrator accounts</p>
    </div>
    <%= link_to new_admin_user_path, class: "btn btn-primary" do %>
      <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
      </svg>
      Create Admin User
    <% end %>
  </div>

  <!-- Admin Users Table -->
  <div class="card">
    <% if @admin_users.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-4 text-gray-500 uppercase tracking-wider">
                Email Address
              </th>
              <th class="px-6 py-3 text-left text-4 text-gray-500 uppercase tracking-wider">
                Created
              </th>
              <th class="px-6 py-3 text-left text-4 text-gray-500 uppercase tracking-wider">
                Last Login
              </th>
              <th class="px-6 py-3 text-left text-4 text-gray-500 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @admin_users.each do |admin_user| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-3 text-gray-900"><%= admin_user.email_address %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-3 text-gray-900">
                    <%= admin_user.created_at.strftime("%b %d, %Y") %>
                  </div>
                  <div class="text-4 text-gray-500">
                    <%= admin_user.created_at.strftime("%l:%M %p") %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if admin_user.last_logged_in_at %>
                    <div class="text-3 text-gray-900">
                      <%= time_ago_in_words(admin_user.last_logged_in_at) %> ago
                    </div>
                    <div class="text-4 text-gray-500">
                      <%= admin_user.last_logged_in_at.strftime("%b %d, %Y at %l:%M %p") %>
                    </div>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      Never
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if admin_user != Current.admin_user %>
                    <%= link_to admin_user_path(admin_user), method: :delete,
                        class: "text-4 text-red-600 hover:text-red-900",
                        confirm: "Are you sure you want to delete this admin user? This action cannot be undone." do %>
                      Delete
                    <% end %>
                  <% else %>
                    <span class="text-4 text-gray-400">Current User</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-2.707m1 11.707V18a3 3 0 00-3-3v4.5z" />
        </svg>
        <h3 class="text-2 text-gray-900 mt-4">No admin users</h3>
        <p class="text-3 text-gray-500 mt-2">Get started by creating a new admin user.</p>
        <div class="mt-6">
          <%= link_to new_admin_user_path, class: "btn btn-primary" do %>
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
            </svg>
            Create Admin User
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>