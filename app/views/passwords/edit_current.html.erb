<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-1 text-gray-900">Change Password</h1>
    <p class="text-3 text-gray-600 mt-2">Update your account password</p>
  </div>

  <!-- Password Change Form -->
  <%= form_with model: @admin_user, url: account_password_path, method: :patch, local: true, class: "space-y-6" do |form| %>
    
    <% if @admin_user.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= pluralize(@admin_user.errors.count, "error") %> prohibited this password from being updated:
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @admin_user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Current Email (read-only) -->
    <div>
      <label class="form-label">Email Address</label>
      <div class="form-input bg-gray-50 text-gray-500">
        <%= @admin_user.email_address %>
      </div>
      <p class="text-4 text-gray-500 mt-1">Your email address cannot be changed</p>
    </div>

    <!-- New Password Field -->
    <div>
      <%= form.label :password, "New Password", class: "form-label" %>
      <%= form.password_field :password, 
          required: true, 
          autocomplete: "new-password", 
          placeholder: "Enter new password", 
          maxlength: 72,
          class: "form-input" %>
    </div>

    <!-- Confirm Password Field -->
    <div>
      <%= form.label :password_confirmation, "Confirm New Password", class: "form-label" %>
      <%= form.password_field :password_confirmation, 
          required: true, 
          autocomplete: "new-password", 
          placeholder: "Confirm new password", 
          maxlength: 72,
          class: "form-input" %>
    </div>

    <!-- Action Buttons -->
    <div class="flex items-center justify-end space-x-3 pt-6 border-t border-gray-200">
      <%= link_to "Cancel", root_path, class: "btn btn-secondary" %>
      <%= form.submit "Update Password", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>